# ── json, jsonb ──
# Both are stored in Lance as normalized JSON text (via serde_json).

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_types_json.lance',
    $$SELECT '{"a":1}'::json AS j, '{"b":2}'::jsonb AS jb$$,
    mode := 'create'
  );
----
1 t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_types_json', '${LANCE_WRITE_DIR}/t_types_json.lance', batch_size => NULL);

query TT
SELECT j, jb FROM t_types_json;
----
{"a":1} {"b":2}

# ── Data integrity comparison: write N rows, read them back, compare ──
# This creates a PG temp table, writes it to Lance, reads back via FDW,
# and confirms every row matches using EXCEPT.

statement ok
CREATE TEMP TABLE src_compare(id int4, val text, score float8);

statement ok
INSERT INTO src_compare
SELECT v, 'item_' || v::text, (v * 1.1)::float8 FROM generate_series(1,50) v;

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_compare.lance',
    'SELECT id, val, score FROM src_compare ORDER BY id',
    mode := 'create'
  );
----
50 t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_compare', '${LANCE_WRITE_DIR}/t_compare.lance', batch_size => NULL);

query I
SELECT count(*) FROM t_compare;
----
50

# Source minus Lance should yield zero rows (all source rows exist in Lance)
query I
SELECT count(*) FROM (
  SELECT id, val FROM src_compare
  EXCEPT
  SELECT id, val FROM t_compare
) diff;
----
0

# Lance minus Source should also yield zero rows
query I
SELECT count(*) FROM (
  SELECT id, val FROM t_compare
  EXCEPT
  SELECT id, val FROM src_compare
) diff;
----
0
