# ── lance_append: large number of rows (stress test) ──

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_stress.lance',
    'SELECT v::int4 AS id, (''name_'' || v::text) AS name FROM generate_series(1,10000) v',
    mode := 'create',
    batch_size := 500
  );
----
10000 t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_stress', '${LANCE_WRITE_DIR}/t_stress.lance', batch_size => NULL);

query I
SELECT count(*) FROM t_stress;
----
10000

query I
SELECT count(DISTINCT id) FROM t_stress;
----
10000

# ── Idempotent merge: merge same data twice, count should stay the same ──

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_idemp.lance',
    'SELECT v::int4 AS id, ''val_'' || v::text AS name FROM generate_series(1,5) v',
    mode := 'create'
  );
----
5 t

# Merge the same 5 rows again — they all match, so no new rows should appear
query IIII
SELECT rows_merged, rows_inserted IS NULL AS ins_null, rows_updated IS NULL AS upd_null, (duration_ms >= 0) AS time_ok
  FROM lance_merge_insert(
    '${LANCE_WRITE_DIR}/t_idemp.lance',
    'SELECT v::int4 AS id, ''val_'' || v::text AS name FROM generate_series(1,5) v',
    ARRAY['id'],
    when_matched := 'update',
    when_not_matched := 'insert'
  );
----
5 t t t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_idemp', '${LANCE_WRITE_DIR}/t_idemp.lance', batch_size => NULL);

# Still exactly 5 rows
query I
SELECT count(*) FROM t_idemp;
----
5

# ── Delete all then append — verify dataset is reusable after emptying ──

query II
SELECT (fragments_removed >= 0) AS ok, (duration_ms >= 0) AS time_ok
  FROM lance_delete(
    '${LANCE_WRITE_DIR}/t_idemp.lance',
    'id >= 0'
  );
----
t t

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_idemp.lance',
    'SELECT 42::int4 AS id, ''reborn''::text AS name',
    mode := 'append'
  );
----
1 t

statement ok
DROP FOREIGN TABLE IF EXISTS t_idemp CASCADE;

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_idemp', '${LANCE_WRITE_DIR}/t_idemp.lance', batch_size => NULL);

query IT
SELECT id, name FROM t_idemp;
----
42 reborn
