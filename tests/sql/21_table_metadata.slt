# Direct Lance table metadata helpers avoid temp FDW objects for schema/history/fragment inspection.

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_table_metadata.lance',
    $$SELECT * FROM (VALUES
      (1::int4, 'alpha'::text),
      (2::int4, 'beta'::text),
      (3::int4, 'gamma'::text)
    ) AS t(id, label)$$,
    mode := 'create'
  );
----
3 t

query ITTT
SELECT rows, (version >= 1)::text, (latest_version >= version)::text, (fragments >= 1)::text
  FROM lance_table_info('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
3 true true true

query IT
SELECT jsonb_array_length(schema->'fields'), (metadata = '{}'::jsonb)::text
  FROM lance_table_info('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
2 true

query TT
SELECT field_path, data_type
  FROM lance_table_fields('${LANCE_WRITE_DIR}/t_table_metadata.lance')
 ORDER BY field_path;
----
id Int32
label Utf8

query I
SELECT rows FROM lance_count_rows('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
3

query I
SELECT rows FROM lance_count_rows('${LANCE_WRITE_DIR}/t_table_metadata.lance', 'id > 1');
----
2

query T
SELECT (count(*) >= 1)::text FROM lance_list_fragments('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
true

query IT
SELECT logical_rows, (fragments >= 1)::text
  FROM lance_fragment_stats('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
3 true

query T
SELECT (count(*) >= 1)::text FROM lance_list_versions('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
true

query T
SELECT (count(*) >= 0)::text FROM lance_list_tags('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
true

query T
SELECT (count(*) >= 0)::text FROM lance_list_branches('${LANCE_WRITE_DIR}/t_table_metadata.lance');
----
true

query TTT
SELECT (read_version >= 1)::text,
       jsonb_typeof(candidate_files),
       (duration_ms >= 0)::text
  FROM lance_cleanup_plan(
    '${LANCE_WRITE_DIR}/t_table_metadata.lance',
    older_than_seconds := 0,
    max_candidate_files := 10
  );
----
true array true