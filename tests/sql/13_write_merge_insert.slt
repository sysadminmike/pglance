# Test lance_merge_insert — upsert rows with match-on-key semantics.

# ── Setup: create a base dataset ──

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_merge_test.lance',
    'SELECT v::int4 AS id, ''original_'' || v::text AS name, v::float8 AS score FROM generate_series(1,5) v',
    mode := 'create'
  );
----
5 t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_merge_base', '${LANCE_WRITE_DIR}/t_merge_test.lance', batch_size => NULL);

query I
SELECT count(*) FROM t_merge_base;
----
5

# ── Merge: update existing + insert new (default behaviour) ──
# Source has ids 3,4,5,6,7 — ids 3-5 exist (update), 6-7 are new (insert)

query IIII
SELECT rows_merged, rows_inserted IS NULL AS ins_null, rows_updated IS NULL AS upd_null, (duration_ms >= 0) AS time_ok
  FROM lance_merge_insert(
    '${LANCE_WRITE_DIR}/t_merge_test.lance',
    'SELECT v::int4 AS id, ''merged_'' || v::text AS name, (v * 10)::float8 AS score FROM generate_series(3,7) v',
    ARRAY['id'],
    when_matched := 'update',
    when_not_matched := 'insert'
  );
----
5 t t t

# Read back — should have 7 rows total. Rows 1,2 unchanged, 3-5 updated, 6-7 new.

statement ok
DROP FOREIGN TABLE IF EXISTS t_merge_base CASCADE;

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_merge_base', '${LANCE_WRITE_DIR}/t_merge_test.lance', batch_size => NULL);

query I
SELECT count(*) FROM t_merge_base;
----
7

# Rows 1,2 should retain original names
query T
SELECT name FROM t_merge_base WHERE id = 1;
----
original_1

query T
SELECT name FROM t_merge_base WHERE id = 2;
----
original_2

# Rows 3-5 should have updated names
query T
SELECT name FROM t_merge_base WHERE id = 3;
----
merged_3

query T
SELECT name FROM t_merge_base WHERE id = 5;
----
merged_5

# Rows 6,7 should be newly inserted
query T
SELECT name FROM t_merge_base WHERE id = 6;
----
merged_6

query T
SELECT name FROM t_merge_base WHERE id = 7;
----
merged_7

# ── Merge with when_matched='nothing' — only inserts, no updates ──

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_merge_nothing.lance',
    'SELECT v::int4 AS id, ''orig_'' || v::text AS name FROM generate_series(1,3) v',
    mode := 'create'
  );
----
3 t

query IIII
SELECT rows_merged, rows_inserted IS NULL AS ins_null, rows_updated IS NULL AS upd_null, (duration_ms >= 0) AS time_ok
  FROM lance_merge_insert(
    '${LANCE_WRITE_DIR}/t_merge_nothing.lance',
    'SELECT v::int4 AS id, ''new_'' || v::text AS name FROM generate_series(2,5) v',
    ARRAY['id'],
    when_matched := 'nothing',
    when_not_matched := 'insert'
  );
----
4 t t t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_merge_nothing', '${LANCE_WRITE_DIR}/t_merge_nothing.lance', batch_size => NULL);

query I
SELECT count(*) FROM t_merge_nothing;
----
5

# Rows 2,3 should still have original names (not updated)
query T
SELECT name FROM t_merge_nothing WHERE id = 2;
----
orig_2

query T
SELECT name FROM t_merge_nothing WHERE id = 3;
----
orig_3

# Rows 4,5 should be newly inserted
query T
SELECT name FROM t_merge_nothing WHERE id = 4;
----
new_4

# ── Merge with when_not_matched='nothing' — only updates, no inserts ──

query II
SELECT rows_written, (duration_ms >= 0) AS ok
  FROM lance_append(
    '${LANCE_WRITE_DIR}/t_merge_upd_only.lance',
    'SELECT v::int4 AS id, ''orig_'' || v::text AS tag FROM generate_series(1,3) v',
    mode := 'create'
  );
----
3 t

query IIII
SELECT rows_merged, rows_inserted IS NULL AS ins_null, rows_updated IS NULL AS upd_null, (duration_ms >= 0) AS time_ok
  FROM lance_merge_insert(
    '${LANCE_WRITE_DIR}/t_merge_upd_only.lance',
    'SELECT v::int4 AS id, ''upd_'' || v::text AS tag FROM generate_series(2,5) v',
    ARRAY['id'],
    when_matched := 'update',
    when_not_matched := 'nothing'
  );
----
4 t t t

statement ok
SELECT lance_import('${SERVER}', '${SCHEMA}', 't_merge_upd_only', '${LANCE_WRITE_DIR}/t_merge_upd_only.lance', batch_size => NULL);

# Should still be 3 rows — no new rows inserted
query I
SELECT count(*) FROM t_merge_upd_only;
----
3

# Row 1 unchanged, rows 2,3 updated
query T
SELECT tag FROM t_merge_upd_only WHERE id = 1;
----
orig_1

query T
SELECT tag FROM t_merge_upd_only WHERE id = 2;
----
upd_2

query T
SELECT tag FROM t_merge_upd_only WHERE id = 3;
----
upd_3

# ── Merge with empty source (zero rows) — no-op ──

query IIII
SELECT rows_merged, rows_inserted IS NULL AS ins_null, rows_updated IS NULL AS upd_null, (duration_ms >= 0) AS time_ok
  FROM lance_merge_insert(
    '${LANCE_WRITE_DIR}/t_merge_upd_only.lance',
    'SELECT 1::int4 AS id, ''x''::text AS tag WHERE false',
    ARRAY['id']
  );
----
0 f f t

# ── Error: empty on_columns ──

statement ok
CREATE OR REPLACE FUNCTION capture_error(sql text)
RETURNS jsonb
LANGUAGE plpgsql AS $$
DECLARE st text; msg text; det text;
BEGIN
  EXECUTE sql;
  RETURN NULL;
EXCEPTION WHEN OTHERS THEN
  GET STACKED DIAGNOSTICS st = RETURNED_SQLSTATE, msg = MESSAGE_TEXT, det = PG_EXCEPTION_DETAIL;
  RETURN jsonb_build_object('sqlstate', st, 'message', msg, 'detail', det);
END $$;

query T
SELECT capture_error(
  'SELECT * FROM lance_merge_insert(''' || '${LANCE_WRITE_DIR}/t_merge_upd_only.lance' || ''', ''SELECT 1::int4 AS id, ''''x''''::text AS tag'', ARRAY[]::text[])'
) IS NOT NULL;
----
t

# ── Error: on_column not in source query ──

query T
SELECT capture_error(
  'SELECT * FROM lance_merge_insert(''' || '${LANCE_WRITE_DIR}/t_merge_upd_only.lance' || ''', ''SELECT 1::int4 AS id, ''''x''''::text AS tag'', ARRAY[''nonexistent''])'
) IS NOT NULL;
----
t

# ── Error: invalid when_matched value ──

query T
SELECT capture_error(
  'SELECT * FROM lance_merge_insert(''' || '${LANCE_WRITE_DIR}/t_merge_upd_only.lance' || ''', ''SELECT 1::int4 AS id, ''''x''''::text AS tag'', ARRAY[''id''], when_matched := ''badval'')'
) IS NOT NULL;
----
t
